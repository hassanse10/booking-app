# ── Database ──────────────────────────────────────────────────────────────────
# Production: set this to your Neon / Supabase / Railway PostgreSQL URL
# Local dev:  leave empty → PGlite is used automatically (no install needed)
DATABASE_URL=

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_32chars

# ── Teacher (hardcoded admin) ─────────────────────────────────────────────────
TEACHER_EMAIL=teacher@example.com
TEACHER_PASSWORD=teacher123
TEACHER_NAME=Ahmed Ben Ali

# ── Email via SMTP ────────────────────────────────────────────────────────────
# Leave SMTP_USER empty to disable emails (app still works without it)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
FRONTEND_URL=https://your-frontend-url.vercel.app
